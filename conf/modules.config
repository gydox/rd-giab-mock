/*
 * publishDir directives for each MOCK_STAGE_*. Paths mirror the conventional
 * nf-core/raredisease output layout so analyst-authored OutputDecls in
 * flowgate can use the same globs they'd use against the real pipeline.
 */

process {
    withName: 'MOCK_STAGE_MITO|MOCK_STAGE_HAPLOGREP' {
        publishDir = [
            path: { "${params.outdir}/${meta.case_id}/mitochondria" },
            mode: 'copy',
            saveAs: { it == 'versions.yml' ? null : it }
        ]
    }
    withName: 'MOCK_STAGE_SNV|MOCK_STAGE_SNV_ROHANN|MOCK_STAGE_SNV_SCORED|MOCK_STAGE_SNV_RANKED' {
        publishDir = [
            path: { "${params.outdir}/${meta.case_id}/snv" },
            mode: 'copy'
        ]
    }
    withName: 'MOCK_STAGE_SV' {
        publishDir = [
            path: { "${params.outdir}/${meta.case_id}/sv" },
            mode: 'copy'
        ]
    }
    withName: 'MOCK_STAGE_STR' {
        publishDir = [
            path: { "${params.outdir}/${meta.case_id}/repeat_expansions" },
            mode: 'copy'
        ]
    }
    withName: 'MOCK_STAGE_PEDDY' {
        publishDir = [
            path: { "${params.outdir}/${case_id}/peddy" },
            mode: 'copy'
        ]
    }
    withName: 'MOCK_STAGE_MULTIQC' {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: 'copy'
        ]
    }
}
