{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://raw.githubusercontent.com/gydox/rd-giab-mock/main/assets/schema_input.json",
    "title": "gydox/rd-giab-mock samplesheet schema",
    "description": "Same shape as nf-core/raredisease but fastq paths are not existence-checked (mock doesn't read them).",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "meta": ["id", "sample"],
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces"
            },
            "lane": {
                "type": ["number", "string"],
                "meta": ["lane"]
            },
            "fastq_1": {
                "type": "string",
                "errorMessage": "fastq_1 must be a path or URL with no spaces",
                "anyOf": [
                    { "pattern": "^\\S+$" },
                    { "maxLength": 0 }
                ]
            },
            "fastq_2": {
                "type": "string",
                "errorMessage": "fastq_2 must be a path or URL with no spaces",
                "anyOf": [
                    { "pattern": "^\\S+$" },
                    { "maxLength": 0 }
                ]
            },
            "sex": {
                "type": ["string", "integer"],
                "meta": ["sex"],
                "enum": ["1", "2", "other", 1, 2]
            },
            "phenotype": {
                "type": "integer",
                "meta": ["phenotype"],
                "enum": [0, 1, 2]
            },
            "paternal_id": {
                "type": "string",
                "meta": ["paternal"],
                "default": "0",
                "anyOf": [
                    { "pattern": "^\\S+$" },
                    { "maxLength": 0 }
                ]
            },
            "maternal_id": {
                "type": "string",
                "meta": ["maternal"],
                "default": "0",
                "anyOf": [
                    { "pattern": "^\\S+$" },
                    { "maxLength": 0 }
                ]
            },
            "case_id": {
                "type": "string",
                "meta": ["case_id"],
                "pattern": "^\\S+$",
                "errorMessage": "case_id must be provided and cannot contain spaces"
            }
        },
        "required": ["sample", "case_id"]
    }
}
