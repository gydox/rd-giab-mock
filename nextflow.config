/*
 * Mock rd-giab pipeline — see README.md
 */

nextflow.enable.dsl = 2

manifest {
    name            = 'gydox/rd-giab-mock'
    author          = 'Synapsys'
    homePage        = 'https://github.com/gydox/rd-giab-mock'
    description     = 'Mock rare-disease pipeline producing canned outputs in <1 minute. Drop-in for flowgate E2E testing.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.1.0'
}

plugins {
    id 'nf-validation@1.1.3'
}

params {
    // Required (set at runtime)
    input  = null
    outdir = null

    // Validation
    validate_params      = true
    monochrome_logs      = false
    help                 = false
    version              = false

    // Accepted but ignored — kept so flowgate's onprem-params.json validates cleanly.
    genome                              = null
    igenomes_ignore                     = true
    igenomes_base                       = null
    fasta                               = null
    fasta_fai                           = null
    fai                                 = null
    dict                                = null
    sequence_dictionary                 = null
    bwa                                 = null
    bwamem2                             = null
    known_dbsnp                         = null
    known_dbsnp_tbi                     = null
    known_indels                        = null
    known_indels_tbi                    = null
    known_indels_2                      = null
    known_indels_2_tbi                  = null
    dbsnp                               = null
    dbsnp_tbi                           = null
    gnomad                              = null
    gnomad_tbi                          = null
    gnomad_af                           = null
    gnomad_af_idx                       = null
    vep_genome                          = null
    vep_cache                           = null
    vep_cache_version                   = null
    vep_filters                         = null
    cadd_resources                      = null
    cadd_indels                         = null
    cadd_indels_tbi                     = null
    cadd_snvs                           = null
    cadd_snvs_tbi                       = null
    vcfanno_config                      = null
    vcfanno_resources                   = null
    vcfanno_toml                        = null
    vcfanno_lua                         = null
    score_config_snv                    = null
    score_config_sv                     = null
    reduced_penetrance                  = null
    mobile_element_svdb_annotations     = null
    svdb_query_dbs                      = null
    rtgtools_LICENSE                    = null
    ml_model                            = null
    mt_fasta                            = null
    mito_name                           = 'chrM'
    ploidy_model                        = null
    gcnvcaller_model                    = null
    intervals_wgs                       = null
    intervals_y                         = null
    call_interval                       = null
    target_bed                          = null
    variant_catalog                     = null
    variant_caller                      = 'deepvariant'
    aligner                             = 'bwamem2'
    analysis_type                       = 'wgs'
    platform                            = 'illumina'
    rmdup                               = false
    bait_padding                        = 100
    save_reference                      = false
    save_mapped_as_cram                 = false
    skip_cnv_calling                    = false
    skip_snv_annotation                 = false
    skip_sv_annotation                  = false
    skip_mt_analysis                    = false
    skip_mt_annotation                  = false
    skip_fastp                          = false
    skip_haplocheck                     = false
    skip_germlinecnvcaller              = false
    skip_vep_filter                     = false
    gens_switch                         = false
    gens_interval_list                  = null
    gens_pon                            = null
    gens_gnomad_pos                     = null
    readcount_intervals                 = null
    local_genomes                       = null
    multiqc_config                      = null
    multiqc_logo                        = null
    multiqc_methods_description         = null
    email                               = null
    email_on_fail                       = null
    plaintext_email                     = false
    hook_url                            = null

    // Resource caps passed by flowgate — accepted, ignored (mock uses ~0 of everything).
    max_cpus   = null
    max_memory = null
    max_time   = null

    // Mock-specific
    mock_sleep_seconds = 0
}

process {
    // bash:5.2 is alpine + bash. Nextflow's process wrapper requires /bin/bash;
    // plain alpine fails with exit 127 because it only has /bin/sh.
    container = 'bash:5.2'

    withName: 'MOCK_STAGE_.*' {
        cpus   = 1
        memory = '256 MB'
        time   = '5m'
    }
}

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        podman.enabled         = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }
    test {
        params.input  = "${projectDir}/assets/samplesheet.csv"
        params.outdir = 'results'
    }
}

includeConfig 'conf/modules.config'

timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"        ; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/execution_report.html"; overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/execution_trace.txt"  ; overwrite = true }
