{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://raw.githubusercontent.com/gydox/rd-giab-mock/main/nextflow_schema.json",
    "title": "gydox/rd-giab-mock pipeline parameters",
    "description": "Mock rd-giab pipeline producing canned outputs for flowgate E2E testing.",
    "type": "object",
    "definitions": {
        "input_output_options": {
            "title": "Input/output options",
            "type": "object",
            "fa_icon": "fas fa-terminal",
            "required": ["input", "outdir"],
            "properties": {
                "input": {
                    "type": "string",
                    "format": "file-path",
                    "mimetype": "text/csv",
                    "pattern": "^\\S+\\.csv$",
                    "schema": "assets/schema_input.json",
                    "description": "Path to samplesheet CSV (local or s3://)"
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "Output directory (local or s3://)"
                }
            }
        },
        "mock_options": {
            "title": "Mock options",
            "type": "object",
            "properties": {
                "mock_sleep_seconds": {
                    "type": "integer",
                    "default": 0,
                    "description": "Optional sleep per stage, for simulating a slower pipeline."
                }
            }
        },
        "ignored_reference_params": {
            "title": "Ignored reference-data params",
            "description": "Declared so flowgate's onprem-params.json validates. The mock does not use any of these.",
            "type": "object",
            "properties": {
                "genome":                          { "type": ["string", "null"] },
                "igenomes_ignore":                 { "type": ["boolean", "null"] },
                "igenomes_base":                   { "type": ["string", "null"] },
                "fasta":                           { "type": ["string", "null"] },
                "fasta_fai":                       { "type": ["string", "null"] },
                "fai":                             { "type": ["string", "null"] },
                "dict":                            { "type": ["string", "null"] },
                "sequence_dictionary":             { "type": ["string", "null"] },
                "bwa":                             { "type": ["string", "null"] },
                "bwamem2":                         { "type": ["string", "null"] },
                "known_dbsnp":                     { "type": ["string", "null"] },
                "known_dbsnp_tbi":                 { "type": ["string", "null"] },
                "known_indels":                    { "type": ["string", "null"] },
                "known_indels_tbi":                { "type": ["string", "null"] },
                "known_indels_2":                  { "type": ["string", "null"] },
                "known_indels_2_tbi":              { "type": ["string", "null"] },
                "dbsnp":                           { "type": ["string", "null"] },
                "dbsnp_tbi":                       { "type": ["string", "null"] },
                "gnomad":                          { "type": ["string", "null"] },
                "gnomad_tbi":                      { "type": ["string", "null"] },
                "gnomad_af":                       { "type": ["string", "null"] },
                "gnomad_af_idx":                   { "type": ["string", "null"] },
                "vep_genome":                      { "type": ["string", "null"] },
                "vep_cache":                       { "type": ["string", "null"] },
                "vep_cache_version":               { "type": ["integer", "string", "null"] },
                "vep_filters":                     { "type": ["string", "null"] },
                "cadd_resources":                  { "type": ["string", "null"] },
                "cadd_indels":                     { "type": ["string", "null"] },
                "cadd_indels_tbi":                 { "type": ["string", "null"] },
                "cadd_snvs":                       { "type": ["string", "null"] },
                "cadd_snvs_tbi":                   { "type": ["string", "null"] },
                "vcfanno_config":                  { "type": ["string", "null"] },
                "vcfanno_resources":               { "type": ["string", "null"] },
                "vcfanno_toml":                    { "type": ["string", "null"] },
                "vcfanno_lua":                     { "type": ["string", "null"] },
                "score_config_snv":                { "type": ["string", "null"] },
                "score_config_sv":                 { "type": ["string", "null"] },
                "reduced_penetrance":              { "type": ["string", "null"] },
                "mobile_element_svdb_annotations": { "type": ["string", "null"] },
                "svdb_query_dbs":                  { "type": ["string", "null"] },
                "rtgtools_LICENSE":                { "type": ["string", "null"] },
                "ml_model":                        { "type": ["string", "null"] },
                "mt_fasta":                        { "type": ["string", "null"] },
                "mito_name":                       { "type": ["string", "null"] },
                "ploidy_model":                    { "type": ["string", "null"] },
                "gcnvcaller_model":                { "type": ["string", "null"] },
                "intervals_wgs":                   { "type": ["string", "null"] },
                "intervals_y":                     { "type": ["string", "null"] },
                "call_interval":                   { "type": ["string", "null"] },
                "target_bed":                      { "type": ["string", "null"] },
                "variant_catalog":                 { "type": ["string", "null"] },
                "variant_caller":                  { "type": ["string", "null"] },
                "aligner":                         { "type": ["string", "null"] },
                "analysis_type":                   { "type": ["string", "null"] },
                "platform":                        { "type": ["string", "null"] },
                "rmdup":                           { "type": ["boolean", "null"] },
                "bait_padding":                    { "type": ["integer", "null"] },
                "save_reference":                  { "type": ["boolean", "null"] },
                "save_mapped_as_cram":             { "type": ["boolean", "null"] },
                "skip_cnv_calling":                { "type": ["boolean", "null"] },
                "skip_snv_annotation":             { "type": ["boolean", "null"] },
                "skip_sv_annotation":              { "type": ["boolean", "null"] },
                "skip_mt_analysis":                { "type": ["boolean", "null"] },
                "skip_mt_annotation":              { "type": ["boolean", "null"] },
                "skip_fastp":                      { "type": ["boolean", "null"] },
                "skip_haplocheck":                 { "type": ["boolean", "null"] },
                "skip_germlinecnvcaller":          { "type": ["boolean", "null"] },
                "skip_vep_filter":                 { "type": ["boolean", "null"] },
                "gens_switch":                     { "type": ["boolean", "null"] },
                "gens_interval_list":              { "type": ["string", "null"] },
                "gens_pon":                        { "type": ["string", "null"] },
                "gens_gnomad_pos":                 { "type": ["string", "null"] },
                "readcount_intervals":             { "type": ["string", "null"] },
                "local_genomes":                   { "type": ["string", "null"] },
                "multiqc_config":                  { "type": ["string", "null"] },
                "multiqc_logo":                    { "type": ["string", "null"] },
                "multiqc_methods_description":     { "type": ["string", "null"] },
                "email":                           { "type": ["string", "null"] },
                "email_on_fail":                   { "type": ["string", "null"] },
                "plaintext_email":                 { "type": ["boolean", "null"] },
                "hook_url":                        { "type": ["string", "null"] },
                "validate_params":                 { "type": ["boolean", "null"] },
                "monochrome_logs":                 { "type": ["boolean", "null"] },
                "help":                            { "type": ["boolean", "null"] },
                "version":                         { "type": ["boolean", "null"] },
                "max_cpus":                        { "type": ["integer", "null"] },
                "max_memory":                      { "type": ["string", "null"] },
                "max_time":                        { "type": ["string", "null"] }
            }
        }
    },
    "allOf": [
        { "$ref": "#/definitions/input_output_options" },
        { "$ref": "#/definitions/mock_options" },
        { "$ref": "#/definitions/ignored_reference_params" }
    ]
}
